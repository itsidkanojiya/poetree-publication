# API base URL (include /api path). Used by app and Vite dev server proxy.
# Production:
VITE_API_URL=https://api.poetreepublications.com/api

# Local backend (default if not set):
# VITE_API_URL=http://localhost:4000/api

# --- Worksheet/answer-sheet PDFs (production) ---
# If "Failed to load" in live: backend must (1) serve PDF at /uploads/worksheet/pdf/...
# with Content-Type: application/pdf, (2) allow CORS from your frontend origin,
# (3) store full PDF URLs using production domain (not localhost).
# If the modal opens but the PDF area is blank: backend is likely blocking embedding.
# Allow iframe embedding by NOT setting X-Frame-Options (or set frame-ancestors to allow your site).
